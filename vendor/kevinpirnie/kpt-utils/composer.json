{
    "name": "kevinpirnie/kpt-utils",
    "type": "library",
    "description": "A modern PHP 8.2+ utility library.",
    "keywords": [
        "array",
        "cli",
        "collection",
        "crypto",
        "curl",
        "datetime",
        "encryption",
        "env",
        "http",
        "input",
        "paginator",
        "php",
        "sanitize",
        "security",
        "session",
        "string",
        "token",
        "utilities",
        "uuid",
        "validate",
        "pipeline",
        "retry"
    ],
    "homepage": "https://github.com/kpirnie/kp-php-utils",
    "license": "MIT",
    "funding": [
        {
            "type": "paypal",
            "url": "https://www.paypal.biz/kevinpirnie"
        },
        {
            "type": "ko-fi",
            "url": "https://ko-fi.com/kevinpirnie"
        }
    ],
    "authors": [
        {
            "name": "Kevin Pirnie",
            "email": "iam@kevinpirnie.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-openssl": "*",
        "ext-sodium": "*",
        "ext-curl": "*",
        "ext-intl": "*"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "KPT\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "cs-check": "phpcs src --standard=PSR12",
        "cs-fix": "phpcbf src --standard=PSR12",
        "quality": [
            "@cs-check"
        ]
    },
    "support": {
        "issues": "https://github.com/kpirnie/kp-php-utils/issues",
        "source": "https://github.com/kpirnie/kp-php-utils",
        "docs": "https://github.com/kpirnie/kp-php-utils/blob/main/readme.md"
    }
}